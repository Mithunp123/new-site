DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=gradix
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
PORT=3000
UPLOAD_DIR=./uploads
COMMISSION_RATE=10
GOOGLE_CLIENT_ID=your_google_client_id_here

# YouTube Data API v3 — used to fetch real views/likes/comments for YouTube content
# Get from: https://console.cloud.google.com → Enable "YouTube Data API v3"
youtube_date_key=your_youtube_data_api_key_here

# YouTube Analytics API key (reserved for future OAuth-based analytics)
youtube_analytics_key=your_youtube_analytics_key_here

# RapidAPI — used to fetch public Instagram post stats (views, likes, comments)
# Reach/impressions are private metrics and will be estimated even with this key.
# Get from: https://rapidapi.com/logicbuilder/api/instagram-data1
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=instagram-data1.p.rapidapi.com

# Platform fee charged to brands on top of creator budget (percentage)
PLATFORM_FEE_RATE=8
