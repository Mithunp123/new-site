DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=gradix
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
PORT=3000
RUN_MIGRATIONS_ON_START=true
UPLOAD_DIR=./uploads
COMMISSION_RATE=10
GOOGLE_CLIENT_ID=your_google_client_id_here
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
META_GRAPH_VERSION=v25.0
META_APP_ID=1110859957658166
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:3000/auth/facebook/callback

# YouTube Data API v3 — used to fetch real views/likes/comments for YouTube content
# Get from: https://console.cloud.google.com → Enable "YouTube Data API v3"
youtube_date_key=your_youtube_data_api_key_here

# YouTube Analytics API key (reserved for future OAuth-based analytics)
youtube_analytics_key=your_youtube_analytics_key_here

# Platform fee charged to brands on top of creator budget (percentage)
PLATFORM_FEE_RATE=8
