{
  "info": {
    "name": "Gradix API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Creator Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Sharma\",\n  \"email\": \"priya@test.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"Test@1234\",\n  \"location\": \"Mumbai\",\n  \"languages_known\": [\"Hindi\", \"English\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/auth/creator/register" }
          }
        },
        {
          "name": "Creator Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('creatorToken', pm.response.json().data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"priya@test.com\",\n  \"password\": \"Test@1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/auth/creator/login" }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "creatorToken", "value": "" },
    { "key": "brandToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "campaignId", "value": "" }
  ]
}
